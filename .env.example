# Copy this file to .env.local for local development.
# In dev, leave VITE_API_URL empty — Vite will proxy /api to the backend.
# In production (Vercel), set it to your deployed backend URL.

# VITE_API_URL=https://your-backend.railway.app

# Override the dev proxy target if your backend runs on a different port
# VITE_BACKEND_URL=http://localhost:3001
